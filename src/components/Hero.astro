---
import { SITE } from '../consts';
---
<section class="hero">
  <div class="eyebrow wave-in">{SITE.eyebrow}</div>
  <h1 class="wave-in">{SITE.tagline} <em>roman</em> éclaire de nouveaux possibles.</h1>
  <p class="lede wave-in">{SITE.lede}</p>
  <figure class="hero-figure wave-in">
    <picture>
      <source srcset="/img/arbre.webp" type="image/webp">
      <img class="hero-tree" src="/img/arbre.png" alt="Arbre-réseau : un chêne dont les branches se dissolvent en dendrites neuronales" width="560" height="420" loading="eager" fetchpriority="high">
    </picture>
  </figure>
</section>
